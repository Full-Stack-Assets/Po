# ─── LLM Provider API Keys ───────────────────────────────
# Set at least ONE provider to get started.
# The system auto-discovers which providers are available.

# OpenAI (GPT-4.1, o4-mini, etc.)
OPENAI_API_KEY=sk-...

# Anthropic (Claude Sonnet 4.5, Opus 4, Haiku 3.5)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com  # optional; for proxies

# Azure OpenAI (enterprise deployments)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4.1

# Google Gemini (2.5 Pro, 2.5 Flash, 2.0 Flash)
GOOGLE_API_KEY=

# Mistral (Large, Small, Codestral)
MISTRAL_API_KEY=

# OpenRouter (200+ models via one API key — openrouter.ai)
OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_DEFAULT_MODEL=openai/gpt-4.1-mini
# OPENROUTER_TITLE=Po AI Operator
# OPENROUTER_REFERER=https://your-site.com

# DeepSeek (OpenAI-compatible; fills the OpenAI slot when OPENAI_API_KEY is unset)
# DEEPSEEK_API_KEY=sk-...

# Ollama (local models — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Action Tools ────────────────────────────────────────
# Resend (transactional email — used by the send_email tool)
# RESEND_API_KEY=re_...

# ─── Trust-layer persistence (optional) ──────────────────
# If set (and asyncpg is installed), approvals/runs/validations are persisted
# to Postgres and survive restarts. If unset, an in-memory store is used.
# DATABASE_URL=postgresql://user:password@localhost:5432/po

# ─── Authentication ──────────────────────────────────────
# PO_AUTH_ENABLED=true        # enable JWT + API key user auth
# PO_JWT_SECRET=change-me     # secret for JWT signing (required in production)

# ─── Production settings ─────────────────────────────────
# PO_ENV=production           # enables structured logging, disables /docs
# PO_API_KEY=your-secret-key  # bearer token required on all endpoints (except /v2/health)
# PO_CORS_ORIGINS=https://your-domain.com,https://your-dashboard.vercel.app
